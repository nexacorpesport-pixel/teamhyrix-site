<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TeamHyriX - Accueil</title>
<link rel="stylesheet" href="style.css">
<script src="https://cdn.jsdelivr.net/npm/particles.js"></script>

<script>
particlesJS("particles-js", {
  particles: {
    number: { value: 60 },
    color: { value: "#00f5ff" },
    shape: { type: "circle" },
    opacity: { value: 0.5 },
    size: { value: 3 },
    move: { enable: true, speed: 2 }
  }
});
</script>

<body>

<div id="particles-js"></div>

<header>
    <div class="logo">TeamHyriX</div>

    <div class="menu-toggle">☰</div>

    <nav>
        <a href="index.html">Accueil</a>
        <a href="presentation.html">Présentation</a>
        <a href="rosters.html">Rosters</a>
        <a href="reseaux.html">Réseaux</a>
        <a href="boutique.html">Boutique</a>
    </nav>
</header>

<section>
    <h1 class="hidden">TEAMHYRIX</h1>
    <p style="margin-top:20px; font-size:20px; letter-spacing:3px; color:cyan;">
Built for Dominance.
</p>
    <p class="hidden">Excellence • Discipline • Performance</p>
</section>

<script src="script.js"></script>

<script>
particlesJS("particles-js", {
  particles: {
    number: { value: 80 },
    color: { value: "#00ffff" },
    size: { value: 3 },
    move: { speed: 2 }
  }
});
</script>

</body>
</html>
